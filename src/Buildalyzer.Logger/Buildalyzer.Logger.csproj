<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../../package.props" />

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeBuildOutput>true</IncludeBuildOutput>
    <Description>The MSBuild logger for Buildalyzer. Not intended to be used directly.</Description>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);PackLogger</TargetsForTfmSpecificBuildOutput>
    <PackageId>Buildalyzer.Logger</PackageId>
    <PackageValidationBaselineVersion>8.0.0</PackageValidationBaselineVersion>
    <PackageReleaseNotes>
      <![CDATA[
ToBeReleased
- Replaced MsBuildPipeLogger with XenoAtom.MsBuildPipeLogger.
- Publish SBOM.
      ]]>
    </PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.10.46" PrivateAssets="all" />
    <!-- XenoAtom.MsBuildPipeLogger ships the logger as copy-to-output content (not a lib reference),
         so restore it for the path/content, but reference the logger assembly directly below. -->
    <PackageReference Include="XenoAtom.MsBuildPipeLogger" Version="1.0.4-local" PrivateAssets="all" GeneratePathProperty="true" ExcludeAssets="compile;runtime;contentFiles" />
  </ItemGroup>

  <ItemGroup>
    <!-- Compile against the bundled logger assembly (BuildalyzerLogger derives from PipeLogger).
         Private=true copies it next to Buildalyzer.Logger.dll so MSBuild can load it at runtime. -->
    <Reference Include="XenoAtom.MsBuildPipeLogger.Logger">
      <HintPath>$(PkgXenoAtom_MsBuildPipeLogger)\contentFiles\any\any\XenoAtom.MsBuildPipeLogger\XenoAtom.MsBuildPipeLogger.Logger.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <!-- Get the logger files for later use -->
  <Target Name="GetLoggerFiles" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <LoggerFiles Include="$(PkgXenoAtom_MsBuildPipeLogger)\contentFiles\any\any\XenoAtom.MsBuildPipeLogger\*.dll" />
    </ItemGroup>
    <Error Condition="'@(LoggerFiles)' == ''" Text="Could not find XenoAtom.MsBuildPipeLogger logger files" />
  </Target>

  <!-- Workaround to pack package reference directly
       See https://github.com/NuGet/Home/issues/3891
       And https://github.com/NuGet/Home/issues/4837 -->
  <Target Name="PackLogger" DependsOnTargets="GetLoggerFiles">
    <ItemGroup>
      <BuildOutputInPackage Include="@(LoggerFiles)" />
    </ItemGroup>
  </Target>

</Project>
