<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../../package.props" />

  <PropertyGroup>
    <TargetFrameworks>net6.0;net8.0</TargetFrameworks>
    <PackageId>Buildalyzer</PackageId>
    <PackageValidationBaselineVersion>8.0.0</PackageValidationBaselineVersion>
    <PackageReleaseNotes>
      <![CDATA[
ToBeReleased
- Replaced MsBuildPipeLogger with XenoAtom.MsBuildPipeLogger.
- Drop Buildalyzer.EmptyDisposable. (BREAKING)
- Publish SBOM.
- Introduction of SolutionInfo and ProjectInfo.
- Marked IAnalyzerManger.SolutionFile and IAnalyzer.SolutionFilePath as obsolete.
- Support SLNX.
]]>
    </PackageReleaseNotes>
  </PropertyGroup>

  <!-- Compile-time-only MSBuild engine references; resolved from the SDK at runtime via MSBuildLocator. -->
  <Import Project="../../msbuild-references.props" />

  <ItemGroup>
    <!-- MSBuildLocator registers the SDK's MSBuild at startup (see MSBuildLocatorBootstrap). This is a
         real runtime dependency, so it flows to consumers (unlike the compile-only references above).
         1.9.0+ dropped its net6.0 asset, so pin the last net6.0-capable version there. -->
    <PackageReference Include="Microsoft.Build.Locator" Version="1.11.2" Condition="'$(TargetFramework)' != 'net6.0'" />
    <PackageReference Include="Microsoft.Build.Locator" Version="1.7.8" Condition="'$(TargetFramework)' == 'net6.0'" />
    <!-- Buildalyzer-internal compile references not part of the shared API surface; excluded at runtime. -->
    <PackageReference Include="Microsoft.Build.Tasks.Core" Version="17.10.46" ExcludeAssets="runtime" PrivateAssets="all" />
    <PackageReference Include="NuGet.Frameworks" Version="6.9.1" ExcludeAssets="runtime" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="[4,)" />
    <PackageReference Include="Microsoft.CodeAnalysis.VisualBasic" Version="[4,)" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="6.0.0" />
    <PackageReference Include="Microsoft.VisualStudio.SolutionPersistence" Version="1.0.52" />
    <PackageReference Include="XenoAtom.MsBuildPipeLogger" Version="1.0.1" ExcludeAssets="contentFiles" />
  </ItemGroup>

  <ItemGroup Label="Build dependencies">
    <PackageReference PrivateAssets="all" Include="PolySharp" Version="1.15.0" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Buildalyzer.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Buildalyzer.Workspaces</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Buildalyzer.Logger/Buildalyzer.Logger.csproj" />
  </ItemGroup>

</Project>
